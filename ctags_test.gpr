project Ctags_Test is
   for Languages use ("Ada", "C++");
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("main.adb");

   package Compiler is
      for Switches ("C++") use ("-std=c++17");
   end Compiler;

   package Linker is
      for Switches ("Ada") use ("-lstdc++");
   end Linker;
end Ctags_Test;
